{
  "name": "browser-youtube-play-all",
  "version": "0.4.2",
  "private": true,
  "description": "Adds a 'Play All' button to YouTube, allowing video playback in Latest, Popular, or Oldest order.",
  "type": "module",
  "scripts": {
    "build": "conc bun:typecheck \"bun:build:*\"",
    "build:chrome": "wxt build -b chrome",
    "build:firefox": "wxt build -b firefox",
    "ci": "conc \"bun:ci:*\"",
    "ci:biome": "biome check",
    "ci:bun": "bun ci",
    "ci:sort-package-json": "sort-package-json package.json --check",
    "ci:typecheck": "bun run typecheck",
    "dev": "conc bun:typecheck bun:dev:chrome --restart-tries 1",
    "dev-all": "conc bun:typecheck \"bun:dev:*\" --restart-tries 1",
    "dev:chrome": "wxt -b chrome",
    "dev:firefox": "wxt -b firefox",
    "fix": "conc \"bun:fix:*\"",
    "fix:biome": "biome check --write",
    "fix:bun": "bun install",
    "fix:sort-package-json": "sort-package-json package.json",
    "publish": "bun run zip && wxt submit",
    "publish-init": "wxt submit init",
    "publish-refresh-token-init": "bunx chrome-webstore-upload-keys",
    "setup": "bun install && wxt prepare && bunx lefthook install && bunx playwright install chromium firefox",
    "test": "bun run build && bunx playwright test tests/e2e",
    "test-specs": "bun run build && bunx playwright test tests/specs",
    "test-ui-mode": "bun run build && bunx playwright test --ui",
    "typecheck": "tsc --noEmit",
    "zip": "conc \"bun:zip:*\"",
    "zip:chrome": "wxt zip -b chrome",
    "zip:firefox": "wxt zip -b firefox"
  },
  "dependencies": {
    "eventemitter3": "^5.0.4"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.13",
    "@playwright/test": "^1.59.1",
    "@types/chrome": "^0.1.40",
    "concurrently": "^9.2.1",
    "lefthook": "^2.1.6",
    "playwright-webextext": "^0.0.5",
    "sort-package-json": "^3.6.1",
    "typescript": "^6.0.3",
    "wxt": "^0.20.25"
  }
}
